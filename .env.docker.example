# ──────────────────────────────────────────────────
#  FarmaCompara — Plantilla de variables de entorno Docker
#  Copiar a .env y ajustar los valores antes de levantar
#  los contenedores. NUNCA subir .env a git.
# ──────────────────────────────────────────────────

# ── Base de datos externa ───────────────────────────────
# La BD corre en un proceso externo; ajustar el host/puerto real.
DB_HOST=localhost         # o IP/hostname del servidor de BD
DB_PORT=5432
DB_NAME=farmacompara
DB_USER=farma_user
DB_PASSWORD=cambia_esta_password
DATABASE_URL=postgresql://farma_user:cambia_esta_password@localhost:5432/farmacompara

# ── Medios del scrapper ─────────────────────────────────
# Ruta absoluta en el HOST al directorio de imágenes .webp
MEDIA_PRODUCTOS_DIR=/drive/axonode/demos/farmacompara_scrapper/media/productos

# ── URL pública de la aplicación ───────────────────────
# En producción poner el dominio real, ej: https://farmacompara.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
